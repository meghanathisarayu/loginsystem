# ===========================================
# MongoDB Connection
# ===========================================
# For Local Development (MongoDB Compass):
MONGODB_URI=mongodb://localhost:27017/login_system

# For Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/login_system?retryWrites=true&w=majority

# ===========================================
# Server Port
# ===========================================
PORT=5000

# ===========================================
# JWT Secret Key (Use strong random string)
# ===========================================
JWT_SECRET=your_jwt_secret_key_here

# ===========================================
# Frontend URL (For CORS)
# ===========================================
# Local:
FRONTEND_URL=http://localhost:5173

# Production (Vercel):
# FRONTEND_URL=https://your-frontend-name.vercel.app

# ===========================================
# EmailJS Configuration
# ===========================================
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
